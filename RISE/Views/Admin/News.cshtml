@model List<RISE.Models.News>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    ViewData["Title"] = "Manage News";
}

<div class="container mt-4">
    <h2>News Management</h2>

    <a asp-action="CreateNews" class="btn btn-success mb-3">Add New News</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Title</th>
                <th>Content</th>
                <th>Posted At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var news in Model)
            {
                <tr>
                    <td>@news.Title</td>
                    <td>@news.Content</td>
                    <td>@news.PostedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="EditNews" asp-route-id="@news.Id" class="btn btn-primary btn-sm">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>