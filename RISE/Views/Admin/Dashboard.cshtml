@model RISE.Models.AdminDashboardViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<h2>Admin Dashboard</h2>

<div class="row g-3 mt-3">
    <div class="col-md-2">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">News</h5>
                <p class="card-text">@Model.NewsCount news</p>
                <a href="/Admin/News" class="btn btn-light btn-sm">Manage News</a>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">FAQ</h5>
                <p class="card-text">@Model.FAQCount FAQs</p>
                <a href="/Admin/FAQ" class="btn btn-light btn-sm">Manage FAQ</a>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Subscribers</h5>
                <p class="card-text">@Model.SubscribersCount</p>
                <a href="/Admin/Subscribers" class="btn btn-light btn-sm">View Subscribers</a>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Competitions</h5>
                <p class="card-text">@Model.CompetitionsCount events</p>
                <a href="/Admin/Competitions" class="btn btn-light btn-sm">Manage Competitions</a>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h5 class="card-title">Registrations</h5>
                <p class="card-text">@Model.RegistrationsCount participants</p>
                <a href="/Admin/Competitions" class="btn btn-light btn-sm">View Registrations</a>
            </div>
        </div>
    </div>
</div>
