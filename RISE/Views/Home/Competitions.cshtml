@model List<RISE.Models.Competition>

@{
    ViewData["Title"] = "Competitions";
}

<div class="container mt-4">
    <h2>Competitions History & Upcoming</h2>

    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Location</th>
                <th>Description</th>
                <th>Results</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var comp in Model)
            {
                <tr>
                    <td>@comp.Title</td>
                    <td>@comp.Date.ToString("dd MMM yyyy")</td>
                    <td>@comp.Location</td>
                    <td>@comp.Description</td>
                    <td>
                        @if(!string.IsNullOrWhiteSpace(comp.Results))
                        {
                            <!-- hidden container with results -->
                            <div class="d-none competition-results">
                                @Html.Raw(comp.Results.Replace("\n", "<br />"))
                            </div>

                            <button class="btn btn-sm btn-outline-primary btn-results"
                                    data-bs-toggle="modal"
                                    data-bs-target="#resultsModal"
                                    data-title="@comp.Title">
                                View
                            </button>
                        }
                        else
                        {
                            <em>Pending</em>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- RESULTS MODAL -->
<div class="modal fade" id="resultsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="resultsModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="resultsModalBody">
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>
