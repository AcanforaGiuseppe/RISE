@model RISE.Models.HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
}

<!-- ================= SLIDER ================= -->
@if(Model.SliderImages != null && Model.SliderImages.Any())
{
    <div id="homeSlider" class="carousel slide mb-5" data-bs-ride="carousel" data-bs-interval="10000">
        <div class="carousel-inner">

            @for(int i = 0; i < Model.SliderImages.Count; i++)
            {
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <img src="@Model.SliderImages[i]"
                         class="d-block w-100 home-slider-img"
                         alt="RISE Calisthenics Slide @(i + 1)" />
                </div>
            }

        </div>

        <button class="carousel-control-prev"
                type="button"
                data-bs-target="#homeSlider"
                data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next"
                type="button"
                data-bs-target="#homeSlider"
                data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
}

<!-- ================= INTRO ================= -->
<div class="text-center mb-5">
    <h1 class="fw-bold">RISE – Raw Inner Strength Evolved</h1>
    <p class="lead">
        You don’t need to be the strongest.
        You just need to start.
    </p>
</div>

<!-- ================= NEWS ================= -->
<h2 class="mb-4">Latest News</h2>

@if(Model.LatestNews == null || !Model.LatestNews.Any())
{
    <p>No news available at the moment.</p>
}
else
{
    <div class="row">
        @foreach(var news in Model.LatestNews)
        {
            <div class="col-md-4">
                <div class="card mb-4 h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@news.Title</h5>

                        <p class="card-text flex-grow-1">
                            @(news.Content.Length > 150
                                                ? news.Content.Substring(0, 150) + "..."
                                                : news.Content)
                        </p>

                        <small class="text-muted">
                            @news.PostedAt.ToString("dd MMM yyyy")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
}