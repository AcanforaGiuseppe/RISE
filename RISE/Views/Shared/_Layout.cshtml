@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RISE Calisthenics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="d-flex flex-column min-vh-100">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="/">RISE</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Competitions">Competitions</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Rules">Rules</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Contact">Contact</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/FAQ">FAQ</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        @if(User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <form method="post" asp-controller="Account" asp-action="Logout">
                                    <button type="submit" class="btn btn-link nav-link">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Login">Admin Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main -->
        <main class="container my-4 flex-fill">
            @RenderBody()
        </main>

        <!-- Footer Newsletter -->
        <footer class="bg-dark text-light py-3 mt-auto">
            <div class="container">
                <div class="row align-items-start">
                    <div class="col-md-8 mb-2 mb-md-0">
                        <h6>Want to stay updated on upcoming competitions?</h6>
                        <p class="mb-2">Subscribe to our newsletter or express your interest in participating!</p>
                        @using(Html.BeginForm("Subscribe", "Newsletter", FormMethod.Post))
                        {
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <input type="email" name="email" placeholder="Enter your email" required class="form-control form-control-sm w-auto" style="min-width: 180px;" />
                                <button type="submit" class="btn btn-primary btn-sm">Subscribe</button>
                            </div>
                        }
                    </div>
                    <div class="col-md-4 text-md-end text-center">
                        <p class="mb-0">&copy; 2025<br />RISE Calisthenics</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>