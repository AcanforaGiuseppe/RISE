@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RISE Calisthenics</title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="d-flex flex-column min-vh-100">

        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">RISE</a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- LEFT MENU -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Competitions">Competitions</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Rules">Rules</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Contact">Contact</a></li>
                        <li class="nav-item"><a class="nav-link" href="/FAQ">FAQ</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Registration/Register">Register</a></li>
                    </ul>

                    <!-- RIGHT MENU -->
                    <ul class="navbar-nav align-items-center">
                        <!-- Dark / Light toggle -->
                        <li class="nav-item me-2">
                            <button id="themeToggle"
                                    class="btn btn-outline-light btn-sm"
                                    title="Toggle Dark / Light mode">
                                <i class="fas fa-moon"></i>
                            </button>
                        </li>

                        @if(User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-info btn-sm"
                                   href="/Admin/Dashboard">
                                    Admin Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <form method="post"
                                      asp-controller="Account"
                                      asp-action="Logout"
                                      class="d-inline">
                                    <button type="submit"
                                            class="btn btn-link nav-link px-0">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   href="/Account/AdminLogin">
                                    Admin Login
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <main class="container my-4 flex-fill">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="bg-dark text-light py-3 mt-auto">
            <div class="container">
                <div class="row align-items-start">
                    <div class="col-md-8 mb-2 mb-md-0">
                        <h6 class="mb-1">Want to stay updated on upcoming competitions?</h6>
                        <p class="mb-2 small">
                            Subscribe to our newsletter or express your interest in participating.
                        </p>

                        @using(Html.BeginForm("Subscribe", "Newsletter", FormMethod.Post))
                        {
                            <div class="d-flex gap-2 align-items-center">
                                <input type="email"
                                       name="email"
                                       required
                                       placeholder="Enter your email"
                                       class="form-control form-control-sm"
                                       style="max-width: 220px;" />
                                <button type="submit"
                                        class="btn btn-primary btn-sm">
                                    Subscribe
                                </button>
                            </div>
                        }
                    </div>

                    <div class="col-md-4 text-md-end text-center">
                        <p class="mb-0 small">
                            &copy; 2025<br />
                            RISE Calisthenics
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
