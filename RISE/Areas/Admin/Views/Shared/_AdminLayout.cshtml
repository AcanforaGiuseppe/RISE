@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin | RISE</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="d-flex flex-column min-vh-100">

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold"
                   href="@Url.Action("Dashboard", "Home", new { area = "Admin" })">
                    Admin Panel
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#adminNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="adminNavbar">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Dashboard", "Home", new { area = "Admin" })">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "News", new { area = "Admin" })">
                                News
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Social", new { area = "Admin" })">
                                Social Feed
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "FAQ", new { area = "Admin" })">
                                FAQ
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Competitions", new { area = "Admin" })">
                                Competitions
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Registrations", new { area = "Admin" })">
                                Registrations
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Newsletter", new { area = "Admin" })">
                                Newsletter
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Users", new { area = "Admin" })">
                                Users
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Sliders", new { area = "Admin" })">
                                Slider Images
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               href="@Url.Action("Index", "Geography", new { area = "Admin" })">
                                Geography
                            </a>
                        </li>
                    </ul>

                    <!-- RIGHT MENU -->
                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item me-2">
                            <button id="themeToggle"
                                    class="btn btn-outline-light btn-sm"
                                    title="Toggle Dark / Light mode"
                                    aria-pressed="false">
                                <i class="fas fa-moon"></i>
                            </button>
                        </li>

                        <li class="nav-item">
                            <form method="post"
                                  asp-area=""
                                  asp-controller="Account"
                                  asp-action="Logout"
                                  class="d-inline">
                                <button type="submit"
                                        class="btn btn-outline-secondary btn-sm">
                                    Logout &amp; Back to website
                                </button>
                            </form>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>

        <main class="container my-4 flex-fill">
            @RenderBody()
        </main>

        <footer class="bg-dark text-light text-center py-2 mt-auto">
            <small>&copy; 2026 RISE Calisthenics | Admin Panel</small>
        </footer>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>