@model RISE.Models.Admin.UserStatisticsViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "User Statistics";
}

<h2>User Statistics</h2>

<!-- METRICS -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card p-3 text-center">
            <strong>Total Users</strong>
            <div class="fs-4">@Model.TotalUsers</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 text-center">
            <strong>Admins</strong>
            <div class="fs-4">@Model.AdminUsers</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 text-center">
            <strong>Users</strong>
            <div class="fs-4">@Model.NormalUsers</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 text-center">
            <strong>Registrations</strong>
            <div class="fs-4">@Model.TotalRegistrations</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <strong>New Users (7 days)</strong>
            <div class="fs-4">@Model.NewUsersLast7Days</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 text-center">
            <strong>New Users (30 days)</strong>
            <div class="fs-4">@Model.NewUsersLast30Days</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 text-center">
            <strong>Newsletter Subscribers</strong>
            <div class="fs-4">@Model.TotalSubscribers</div>
        </div>
    </div>
</div>

<!-- CHART -->
<h4 class="mt-4">User Growth (Last 30 Days)</h4>
<canvas id="usersChart" height="100"></canvas>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(
                            Model.UsersPerDay.Select(x => x.Date.ToString("dd/MM"))
                    )
            );

    const data = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                        Model.UsersPerDay.Select(x => x.Count)
                )
        );

    new Chart(document.getElementById('usersChart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'New users',
                data: data,
                fill: false,
                tension: 0.3
            }]
        }
    });
</script>
}
