@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model RISE.Models.FAQ
<h2>Create FAQ</h2>
<form method="post">
    <div class="mb-2">
        <label class="form-label">Question</label>
        <input class="form-control" asp-for="Question" required />
    </div>
    <div class="mb-2">
        <label class="form-label">Answer</label>
        <textarea class="form-control" asp-for="Answer" rows="5"></textarea>
    </div>
    <button class="btn btn-primary">Save</button>
    <a class="btn btn-secondary"
       asp-area="Admin"
       asp-controller="FAQ"
       asp-action="Index">
        Cancel
    </a>
</form>
