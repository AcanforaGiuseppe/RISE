@model RISE.Models.FAQ
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit FAQ";
}

<h2>Edit FAQ</h2>

<form asp-area="Admin"
      asp-controller="FAQ"
      asp-action="Edit"
      method="post">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Question" class="form-label"></label>
        <input asp-for="Question" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Answer" class="form-label"></label>
        <textarea asp-for="Answer"
                  class="form-control"
                  rows="4"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary"
       asp-area="Admin"
       asp-controller="FAQ"
       asp-action="Index">
        Cancel
    </a>
</form>
