@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model List<RISE.Models.FAQ>
<h2>FAQ</h2>
<a class="btn btn-primary btn-sm mb-3" href="/Admin/FAQ/Create">Create</a>
<table class="table table-sm">
    <thead><tr><th>Question</th><th></th></tr></thead>
    <tbody>
        @foreach(var f in Model)
        {
            <tr>
                <td>@f.Question</td>
                <td class="text-end">
                    <a class="btn btn-outline-secondary btn-sm" href="/Admin/FAQ/Edit/@f.Id">Edit</a>
                    <a class="btn btn-outline-danger btn-sm" href="/Admin/FAQ/Delete/@f.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
