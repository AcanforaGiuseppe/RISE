@model RISE.Models.Admin.UserRetentionViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>User Retention</h2>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <strong>Total Users</strong>
            <div class="fs-4">@Model.TotalUsers</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 text-center">
            <strong>One-Time Users</strong>
            <div class="fs-4">@Model.OneTimeUsers</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 text-center">
            <strong>Returning Users</strong>
            <div class="fs-4">@Model.ReturningUsers</div>
        </div>
    </div>
</div>

<div class="alert alert-info mt-4">
    Retention Rate: <b>@Model.RetentionRate.ToString("0.0")%</b>
</div>
