@model List<RISE.Models.News>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "News";
}

<h2>News</h2>

<a class="btn btn-primary btn-sm mb-3"
   asp-area="Admin"
   asp-controller="News"
   asp-action="Create">
    Create
</a>

<table class="table table-sm align-middle">
    <thead>
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var n in Model)
        {
            <tr>
                <td>@n.Title</td>
                <td>@n.PostedAt.ToString("g")</td>
                <td class="text-end">
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-area="Admin"
                       asp-controller="News"
                       asp-action="Edit"
                       asp-route-id="@n.Id">
                        Edit
                    </a>

                    <form asp-area="Admin"
                          asp-controller="News"
                          asp-action="Delete"
                          asp-route-id="@n.Id"
                          method="post"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Delete this news?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>