@model List<RISE.Models.SocialPost>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Social Posts";
}

<h2>Social Posts</h2>

<a class="btn btn-primary btn-sm mb-3"
   asp-area="Admin"
   asp-controller="Social"
   asp-action="Create">
    Create Post
</a>

<table class="table table-sm align-middle">
    <thead>
        <tr>
            <th>Platform</th>
            <th>Content</th>
            <th>Date</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var post in Model)
        {
            <tr>
                <td>@post.Platform</td>
                <td>@post.Content</td>
                <td>@post.PostedAt.ToString("g")</td>
                <td class="text-end">
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-area="Admin"
                       asp-controller="Social"
                       asp-action="Edit"
                       asp-route-id="@post.Id">
                        Edit
                    </a>

                    <form asp-area="Admin"
                          asp-controller="Social"
                          asp-action="Delete"
                          asp-route-id="@post.Id"
                          method="post"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Delete this post?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
