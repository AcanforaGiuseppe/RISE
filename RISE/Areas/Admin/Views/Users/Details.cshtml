@model RISE.Models.User

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "User Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">User Details</h2>
    <a class="btn btn-outline-secondary"
       asp-area="Admin"
       asp-controller="Users"
       asp-action="Index">
        Back
    </a>
</div>

<div class="card p-4 mb-4">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="text-muted small">Name &amp; Surname</div>
            <div class="fs-5">@Model.FullName</div>
        </div>

        <div class="col-md-6">
            <div class="text-muted small">Email</div>
            <div class="fs-5">@Model.Username</div>
        </div>

        <div class="col-md-4 mt-3">
            <div class="text-muted small">Country</div>
            <div class="fs-5">@Model.Country</div>
        </div>

        <div class="col-md-4 mt-3">
            <div class="text-muted small">City</div>
            <div class="fs-5">@Model.City</div>
        </div>

        <div class="col-md-4 mt-3">
            <div class="text-muted small">Category</div>
            <div class="fs-5">@Model.Category</div>
        </div>

        <div class="col-md-4 mt-3">
            <div class="text-muted small">Role</div>
            <div class="fs-5">@Model.Role</div>
        </div>

        <div class="col-md-4 mt-3">
            <div class="text-muted small">Created</div>
            <div class="fs-5">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
</div>
