@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model RISE.Models.User
<h2>Create User</h2>
<form method="post">
    <div class="mb-2">
        <label class="form-label">Username</label>
        <input class="form-control" asp-for="Username" required />
    </div>
    <div class="mb-2">
        <label class="form-label">Password (dev only)</label>
        <input class="form-control" asp-for="Password" required />
    </div>
    <button class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" href="/Admin/Users">Cancel</a>
</form>
