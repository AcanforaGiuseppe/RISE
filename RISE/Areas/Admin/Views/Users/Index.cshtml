@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


@model List<RISE.Models.User>
<h2>Users</h2>
<a class="btn btn-primary btn-sm mb-3" href="/Admin/Users/Create">Create</a>
<table class="table table-sm">
    <thead><tr><th>Username</th><th></th></tr></thead>
    <tbody>
        @foreach(var u in Model)
        {
            <tr>
                <td>@u.Username</td>
                <td class="text-end">
                    <a class="btn btn-outline-secondary btn-sm" href="/Admin/Users/Edit/@u.Id">Edit</a>
                    <a class="btn btn-outline-danger btn-sm" href="/Admin/Users/Delete/@u.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
