@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@model RISE.Models.ContentBlock
<h2>Edit Content Block</h2>
<form method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-2">
        <label class="form-label">Key</label>
        <input class="form-control" asp-for="Key" required />
    </div>
    <div class="mb-2">
        <label class="form-label">Value</label>
        <textarea class="form-control" asp-for="Value" rows="6"></textarea>
    </div>
    <button class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" href="/Admin/ContentBlocks">Cancel</a>
</form>
